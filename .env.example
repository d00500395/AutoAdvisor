# Runtime
NODE_ENV=production
PORT=3000
# Optional subpath hosting, e.g. /autoadvisor
APP_BASE_PATH=/autoadvisor

# Database
MONGO_URI=mongodb://127.0.0.1:27017/autoadvisor

# Session/Auth
SESSION_SECRET=replace_with_a_long_random_secret
# Comma-separated list of allowed browser origins in production
ALLOWED_ORIGINS=https://autoadvisor.yourdomain.com

# Google Identity Services web client ID used for ID token verification
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Session cookie controls
# Use "true" in production behind HTTPS
SESSION_COOKIE_SECURE=true
# Usually "lax" for same-site app, "none" only if cross-site requests are required
SESSION_COOKIE_SAMESITE=lax
# Optional: set only if you need a specific cookie domain
# SESSION_COOKIE_DOMAIN=.yourdomain.com

# Optional: force trust proxy in non-production-like environments
# TRUST_PROXY=1

# Ollama / AI
OLLAMA_URL=http://127.0.0.1:11434
# On smaller CPU-only servers, a 7B-8B instruct model is usually much faster than gpt-oss:20b
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_TIMEOUT_MS=30000
RAG_TOP_K=3
RAG_CHUNK_CHAR_LIMIT=900
EMBEDDING_MODEL=qwen3-embedding
